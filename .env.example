# AiMANAC Personal Backend — Environment Variables
#
# Copy this file to .env and fill in values.
# Or run ./generate-env.sh to auto-generate all secrets.
#
# NEVER commit .env to version control.

# --- Required (auto-generated by generate-env.sh) ---

# 32-byte hex key for IHP V2 at-rest encryption.
ENCRYPTION_KEY=

# 64-byte hex keys for JWT signing. Must be unique per deployment.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Database password (used by both aimanac and postgres containers).
POSTGRES_PASSWORD=

# --- Optional ---

# Port the server listens on (default: 3000).
# PORT=3000

# Apple Sign-In (leave empty to disable Apple auth).
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=

# AI providers (leave empty if using on-device Phi-4-mini only).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# APNs push notifications (leave empty to disable push).
# APNS_KEY_ID=
# APNS_TEAM_ID=
